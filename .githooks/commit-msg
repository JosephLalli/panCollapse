#!/usr/bin/env bash
set -euo pipefail
message_file="${1:?commit message file required}"
forbidden='claude|anthropic|openai|codex|co-authored-by|generated by (an? )?(ai|assistant|model)|ai-generated'
if grep -iEq "$forbidden" "$message_file"; then
  echo "PROVENANCE BLOCK: commit message contains tool/model attribution." >&2
  exit 1
fi
